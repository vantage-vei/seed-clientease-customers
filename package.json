{
  "name": "seed-clientease-customers",
  "version": "1.0.0",
  "description": "console app for seeding customer information from iwf db to clientease db",
  "main": "src/index.js",
  "bin": "src/index.js",
  "scripts": {
    "test": "echo \"Error: no test specified\" && exit 1",
    "start": "node src/index.js",
    "browse": "node src/browse.js",
    "bundle": "esbuild src/index.js --bundle --platform=node --outfile=dist/bundle.cjs",
    "package": "pkg dist/bundle.cjs --targets node18-win-x64,node18-linux-x64 --output dist/seed-customers",
    "build": "npm run bundle && npm run package",
    "generate-mock": "node scripts/generate-mock-csv.js"
  },
  "author": "lowie t. dichoson",
  "license": "ISC",
  "type": "module",
  "dependencies": {
    "chalk": "^5.6.2",
    "csv-parse": "^6.2.1",
    "dotenv": "^17.4.2",
    "pg": "^8.20.0"
  },
  "devDependencies": {
    "@faker-js/faker": "^10.4.0",
    "esbuild": "^0.28.0",
    "pkg": "^5.8.1"
  }
}
